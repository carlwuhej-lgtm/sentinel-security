# 哨兵安全管理平台 — 环境变量配置
# 复制此文件为 .env 并修改对应值

# ============================================================
# 扫描器模式: simulated (模拟) / real (真实扫描)
# ============================================================
SENTINEL_SCANNER_MODE=real

# ============================================================
# JWT 密钥 (生产环境必改)
# ============================================================
# SENTINEL_JWT_SECRET=your-super-secret-key-min-32-chars

# ============================================================
# SMTP 邮件通知
# ============================================================
# SENTINEL_SMTP_ENABLED=true
# SENTINEL_SMTP_HOST=smtp.example.com
# SENTINEL_SMTP_PORT=587
# SENTINEL_SMTP_USER=alerts@company.com
# SENTINEL_SMTP_PASS=your-smtp-password
# SENTINEL_ALERT_RECIPIENTS=admin@company.com,sec@company.com

# ============================================================
# AI 分析 (OpenAI / Ollama)
# ============================================================
# SENTINEL_AI_PROVIDER=ollama
# SENTINEL_AI_API_KEY=ollama
# SENTINEL_AI_BASE=http://127.0.0.1:11434/v1
# SENTINEL_AI_MODEL=qwen3:8b

# ============================================================
# Flask 服务
# ============================================================
# SENTINEL_HOST=0.0.0.0
# SENTINEL_PORT=5000
# SENTINEL_DEBUG=false
