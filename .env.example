# ── Sentinel Security Platform — 环境配置 ──
# 复制此文件为 backend/.env 并按需修改: cp .env.example backend/.env
#
# 所有变量名前缀 SENTINEL_，与 config.py 严格对齐。

# ═══ 服务端口 ═══
SENTINEL_HOST=0.0.0.0
SENTINEL_PORT=5000
SENTINEL_DEBUG=false

# ═══ 数据库路径 ═══
# 默认使用 backend/sentinel.db，可选自定义
# SENTINEL_DB_PATH=/data/sentinel.db

# ═══ JWT 认证密钥 ═══
# 生产环境务必设置为强随机字符串（>=32字符）
SENTINEL_JWT_SECRET=change-me-in-production-please

# ═══ AI 分析配置 ═══
# 有 API Key 则自动启用；ollama 提供商无 key 也启用
SENTINEL_AI_API_KEY=ollama
# API 端点
SENTINEL_AI_BASE=http://localhost:11434/v1
# 模型名称
SENTINEL_AI_MODEL=qwen3:0.6b
# 提供商: openai | ollama | azure | deepseek
SENTINEL_AI_PROVIDER=ollama

# ═══ 扫描引擎 ═══
# real:     调用实际 CLI 工具（semgrep / trivy / gitleaks 等）
# simulated: V4 已废弃模拟模式，不再生效
SENTINEL_SCANNER_MODE=real

# Semgrep 二进制路径（可选，默认从 PATH 查找）
# SENTINEL_SEMGREP_PATH=D:\service\Anaconda\Scripts\semgrep.EXE

# ═══ 邮件通知（可选）═══
SENTINEL_SMTP_ENABLED=false
SENTINEL_SMTP_HOST=smtp.example.com
SENTINEL_SMTP_PORT=587
SENTINEL_SMTP_USER=sentinel@company.com
SENTINEL_SMTP_PASS=
SENTINEL_SMTP_FROM=sentinel@company.com
SENTINEL_ALERT_RECIPIENTS=admin@company.com

# ═══ 平台访问地址 ═══
SENTINEL_BASE_URL=http://localhost:5000

# ═══ 前端构建（Docker 用）═══
VITE_API_URL=http://localhost:5000
